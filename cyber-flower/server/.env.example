# 赛博养花 — 环境变量配置

# 服务
PORT=3000
NODE_ENV=development

# 微信小程序
WX_APPID=your_appid_here
WX_SECRET=your_secret_here

# MongoDB
MONGODB_URI=mongodb://localhost:27017/cyber-bloom

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# AI服务
AI_IMAGE_ENDPOINT=https://api.stability.ai/v1
AI_IMAGE_API_KEY=your_sd_api_key
AI_LLM_ENDPOINT=https://api.anthropic.com/v1
AI_LLM_API_KEY=your_claude_api_key

# 腾讯云COS
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=cyber-bloom-images
COS_REGION=ap-guangzhou
