<!-- custom-tab-bar — 全局自定义底部导航
     用 design-tokens 颜色 + emoji 占位图标（后续替换为线性 SVG） -->
<view class="tab-bar">
  <view class="tab-bar__item"
    wx:for="{{list}}"
    wx:key="index"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <text class="tab-bar__icon {{selected === index ? 'tab-bar__icon--active' : ''}}">{{item.icon}}</text>
    <text class="tab-bar__label {{selected === index ? 'tab-bar__label--active' : ''}}">{{item.text}}</text>
  </view>
</view>
