<!-- custom-tab-bar — 全局自定义底部导航
     用 design-tokens 颜色 + emoji 图标（零图片依赖） -->
<view class="tab-bar">
  <view
    class="tab-bar__item {{selected === index ? 'tab-bar__item--active' : ''}}"
    wx:for="{{list}}"
    wx:key="index"
    data-index="{{index}}"
    data-path="{{item.pagePath}}"
    bindtap="switchTab"
  >
    <view class="tab-bar__icon">{{item.icon}}</view>
    <view class="tab-bar__text">{{item.text}}</view>
  </view>
</view>
