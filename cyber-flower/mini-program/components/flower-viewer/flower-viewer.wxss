.flower-viewer { position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.flower-canvas { position: absolute; top: 0; left: 0; }
.care-effect-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
.care-effect { width: 100%; height: 100%; }
.care-effect--water { animation: waterGlow 1.5s ease-out; }
.care-effect--fertilize { animation: particleBurst 2s ease-out; }
@keyframes waterGlow { 0% { background: radial-gradient(circle, rgba(100,180,255,0.3), transparent 70%); } 100% { background: transparent; } }
@keyframes particleBurst { 0% { background: radial-gradient(circle, rgba(139,105,20,0.2), transparent 70%); } 100% { background: transparent; } }
.stage-label { position: absolute; bottom: 8rpx; left: 50%; transform: translateX(-50%); background: rgba(255,255,255,0.85); padding: 6rpx 20rpx; border-radius: var(--radius-full); }
.stage-label__text { font-size: var(--text-caption); color: var(--color-primary-700); }
