.garden-page { min-height: 100vh; background: var(--color-bg-primary); display: flex; flex-direction: column; align-items: center; overflow-x: hidden; }
.season-bar { width: 100%; padding: 12rpx 32rpx; display: flex; align-items: center; gap: 8rpx; background: rgba(255,255,255,0.6); backdrop-filter: blur(20rpx); box-sizing: border-box; }
.season-bar__icon { font-size: 22rpx; }
.season-bar__name { font-size: var(--text-body-sm); color: var(--color-text-secondary); }

/* 空花园 */
.garden-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0 48rpx; gap: 16rpx; width: 100%; box-sizing: border-box; }
.garden-empty__hero { font-size: 120rpx; margin-bottom: 16rpx; }
.garden-empty__title { color: var(--color-text-primary); }
.garden-empty__desc { text-align: center; max-width: 400rpx; }
.garden-empty__quick-breed { display: flex; gap: 12rpx; margin-top: 24rpx; width: 100%; max-width: 500rpx; }
.quick-breed-input { flex: 1; height: 80rpx; padding: 0 24rpx; background: var(--color-bg-white); border-radius: var(--radius-lg); font-size: var(--text-body); box-shadow: var(--shadow-sm); }
.quick-breed-btn { width: 140rpx; height: 80rpx; background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-300)); color: #fff; font-size: var(--text-body); font-weight: 600; border-radius: var(--radius-lg); border: none; display: flex; align-items: center; justify-content: center; }

/* 主花园 */
.garden-main { flex: 1; width: 100%; display: flex; flex-direction: column; align-items: center; padding-top: 16rpx; }
.flower-dots { display: flex; gap: 8rpx; padding: 12rpx 0; }
.flower-dots__dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: rgba(62,123,82,0.2); transition: all 300ms ease; }
.flower-dots__dot.active { width: 24rpx; border-radius: 4rpx; background: var(--color-primary-500); }
.flower-name-area { padding: 8rpx 0 4rpx; }
.flower-stage { width: 100%; height: 58vh; display: flex; align-items: center; justify-content: center; }

/* 健康/幸福度 */
.flower-stats { width: 80%; max-width: 500rpx; display: flex; flex-direction: column; gap: 12rpx; padding: 16rpx 0; }
.flower-stat { display: flex; align-items: center; gap: 12rpx; }
.flower-stat__label { font-size: var(--text-body-sm); width: 80rpx; flex-shrink: 0; }
.flower-stat__bar { flex: 1; height: 8rpx; background: rgba(0,0,0,0.06); border-radius: 4rpx; overflow: hidden; }
.flower-stat__fill { height: 100%; border-radius: 4rpx; transition: width 600ms ease; }
.flower-stat__fill--health { background: linear-gradient(90deg, #E57373, #FFC107, #4CAF50); }
.flower-stat__fill--happiness { background: linear-gradient(90deg, #90CAF9, #7C4DFF, #E75480); }
.flower-stat__num { font-size: var(--text-caption); font-weight: 600; color: var(--color-text-secondary); width: 40rpx; text-align: right; }

/* 花语气泡 */
.chat-preview { position: fixed; top: 28%; left: 50%; transform: translateX(-50%); z-index: 20; }
.chat-preview__bubble { padding: 16rpx 28rpx; background: rgba(255,255,255,0.95); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); font-size: var(--text-body); color: var(--color-text-primary); white-space: nowrap; }

/* 底部操作栏 */
.garden-action-bar { position: fixed; bottom: calc(100rpx + env(safe-area-inset-bottom)); left: 0; right: 0; z-index: 10; padding: 0 32rpx; }
.action-row { display: flex; justify-content: space-around; background: rgba(255,255,255,0.88); backdrop-filter: blur(20rpx); border-radius: var(--radius-2xl); padding: 16rpx 8rpx; box-shadow: var(--shadow-lg); }
.action-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; padding: 12rpx 24rpx; border-radius: var(--radius-lg); }
.action-item:active { background: rgba(62,123,82,0.08); transform: scale(0.95); }
.action-icon { font-size: 40rpx; }
.action-label { font-size: var(--text-caption); color: var(--color-text-secondary); }

.garden-loading { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24rpx; }
.loading-spinner { width: 64rpx; height: 64rpx; border: 4rpx solid rgba(62,123,82,0.15); border-top-color: var(--color-primary-500); border-radius: 50%; animation: spin 800ms linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
