<!--
  育种页 — 按设计稿精确还原
  严格使用 design-tokens.wxss 变量，不写死颜色/圆角/间距
  当前为静态 UI + 假数据阶段
-->
<view class="breed-page">

  <!-- ============================================
       自定义顶部栏：返回 + 标题 + AI + 消息
       ============================================ -->
  <view class="top-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="top-bar__inner">
      <view class="top-bar__back" bind:tap="handleBack">
        <text class="top-bar__back-icon">←</text>
      </view>
      <text class="top-bar__title">育种</text>
      <view class="top-bar__actions">
        <view class="top-bar__icon-btn" bind:tap="handleAI">
          <text class="top-bar__icon-emoji">🤖</text>
        </view>
        <view class="top-bar__icon-btn top-bar__icon-btn--badge" bind:tap="handleMessages">
          <text class="top-bar__icon-emoji">💬</text>
          <view class="top-bar__badge"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- ============================================
       主玻璃卡片（大卡，用 backdrop-filter）
       ============================================ -->
  <view class="glass-card">
    <text class="glass-card__hero">✨ 输入关键词生成种子 ✨</text>
    <text class="glass-card__subtitle">用 AI 的灵感，孕育独一无二的花</text>

    <!-- 多行输入框 -->
    <view class="glass-card__input-wrap">
      <textarea
        class="glass-card__input"
        placeholder="描述你心中的花..."
        placeholder-class="glass-card__input-placeholder"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        maxlength="50"
        auto-height
      />
      <text class="glass-card__counter">{{keywordLength}}/50</text>
    </view>

    <!-- 情绪选择 -->
    <text class="glass-card__emotion-label">选择你希望赋予它的情绪</text>
    <view class="emotion-chips">
      <view
        wx:for="{{emotions}}"
        wx:key="id"
        class="emotion-chip {{selectedEmotion === item.id ? 'emotion-chip--selected' : ''}}"
        data-id="{{item.id}}"
        bind:tap="selectEmotion"
      >
        <text class="emotion-chip__emoji">{{item.emoji}}</text>
        <text class="emotion-chip__label">{{item.label}}</text>
      </view>
    </view>

    <!-- 生成按钮：渐变 + 光泽 + 内阴影 -->
    <view class="generate-btn" bind:tap="handleGenerate">
      <text class="generate-btn__text">✨ 生成</text>
    </view>
  </view>

  <!-- ============================================
       "今日免费种子" 卡片（小卡，NO backdrop-filter）
       ============================================ -->
  <view class="section-card">
    <view class="section-card__header">
      <text class="section-card__title">🎁 今日免费种子</text>
      <text class="section-card__hint">每日1次 ⓘ</text>
    </view>
    <view class="daily-grid">
      <view
        wx:for="{{dailySeeds}}"
        wx:key="index"
        class="daily-tile {{item.locked ? 'daily-tile--locked' : ''}}"
      >
        <view class="daily-tile__img" style="background: {{item.color}};"></view>
        <text class="daily-tile__name">{{item.name}}</text>
        <text class="daily-tile__rarity daily-tile__rarity--{{item.rarity}}">{{item.rarityText}}</text>
        <view class="daily-tile__lock-overlay" wx:if="{{item.locked}}">
          <text class="daily-tile__lock-hint">分享解锁</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ============================================
       "我的种子" 卡片（小卡，NO backdrop-filter）
       ============================================ -->
  <view class="section-card">
    <view class="section-card__header">
      <text class="section-card__title">我的种子({{mySeedsCount}})</text>
      <text class="section-card__hint">稀有度 ▾</text>
    </view>
    <scroll-view class="seed-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="seed-scroll__inner">
        <view class="seed-item" wx:for="{{mySeeds}}" wx:key="id">
          <view class="seed-item__img" style="background: {{item.color}};"></view>
          <text class="seed-item__name">{{item.name}}</text>
          <view class="seed-item__rarity seed-item__rarity--{{item.rarity}}">
            <text>{{item.rarityText}}</text>
          </view>
          <text class="seed-item__level">Lv.{{item.level}}</text>
          <view class="seed-item__progress">
            <view class="seed-item__progress-fill" style="width: {{item.progress}}%;"></view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

</view>
