.season-indicator { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; background: rgba(255,255,255,0.6); border-radius: var(--radius-full); }
.season-indicator__icon { font-size: 24rpx; }
.season-indicator__name { font-size: var(--text-body-sm); color: var(--color-text-secondary); }
