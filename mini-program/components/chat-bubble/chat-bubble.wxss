.chat-bubble { display: flex; flex-direction: column; max-width: 80%; }
.chat-bubble--user { align-self: flex-end; align-items: flex-end; }
.chat-bubble__sender { color: var(--color-text-tertiary); margin-bottom: 4rpx; }
.chat-bubble__body { padding: 16rpx 24rpx; border-radius: var(--radius-lg); font-size: var(--text-body); line-height: 1.6; word-break: break-all; }
.chat-bubble__body--flower { background: #E8F5E9; color: var(--color-text-primary); border-bottom-left-radius: 4rpx; }
.chat-bubble__body--user { background: var(--color-bg-white); color: var(--color-text-primary); border-bottom-right-radius: 4rpx; box-shadow: var(--shadow-sm); }
